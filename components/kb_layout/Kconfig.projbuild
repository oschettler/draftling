menu "Keyboard Layouts"

config KB_LAYOUT_ENABLE_US
    bool "US-English (QWERTY)"
    default y
    help
        Enable the US-English QWERTY keyboard layout.

config KB_LAYOUT_ENABLE_UA
    bool "Ukrainian (Cyrillic)"
    default y
    help
        Enable the Ukrainian Cyrillic keyboard layout.

config KB_LAYOUT_ENABLE_DE
    bool "German (QWERTZ)"
    default n
    help
        Enable the German QWERTZ keyboard layout with umlauts.

config KB_LAYOUT_ENABLE_FR
    bool "French (AZERTY)"
    default n
    help
        Enable the French AZERTY keyboard layout with accents.

config KB_LAYOUT_ENABLE_KO
    bool "Korean (Dubeolsik)"
    default n
    help
        Enable the Korean Dubeolsik keyboard layout.
        Maps keys to Hangul Jamo characters.

config KB_LAYOUT_ENABLE_JA
    bool "Japanese (Kana)"
    default n
    help
        Enable the Japanese Kana keyboard layout.
        Maps keys to Hiragana characters (JIS kana input).

config KB_LAYOUT_ENABLE_ZH
    bool "Chinese (Zhuyin/Bopomofo)"
    default n
    help
        Enable the Chinese Zhuyin (Bopomofo) keyboard layout.
        Maps keys to Bopomofo phonetic symbols.

endmenu
